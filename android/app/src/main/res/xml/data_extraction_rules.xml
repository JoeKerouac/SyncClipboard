<?xml version="1.0" encoding="utf-8"?>
<!--
    Disable both cloud and device-to-device backup transports for the app.
    The app stores credentials and AES key in SharedPreferences which would
    otherwise be readable via `adb backup` or Android Auto Backup.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
